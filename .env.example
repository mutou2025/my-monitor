# Gmail 发件配置
# Gmail 应用专用密码可以保留空格，也可以去掉空格。
GMAIL_USER=sender@example.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# 收件人
RECIPIENT_EMAIL=recipient@example.com

# 全局轮询配置（秒）—— 作为各站点的默认值
POLL_INTERVAL_BASE=90
POLL_INTERVAL_JITTER=30

# 按站点覆盖轮询间隔（秒）。
# 格式：{SITE_KEY}_POLL_INTERVAL_BASE / _JITTER
# 支持的 SITE_KEY: TORONTO, KUPER, MONTREAL, EDMONTON, MANITOBA, OTTAWA
# 不设置则自动使用全局值。
# 示例：多伦多考位抢手，加快轮询频率
# TORONTO_POLL_INTERVAL_BASE=20
# TORONTO_POLL_INTERVAL_JITTER=5

# 通知去重窗口（分钟）
NOTIFICATION_DEDUPE_WINDOW=30

# 首次运行如果已经有可报名考位，是否立即通知。默认 false 表示只建立基线。
NOTIFY_ON_FIRST_RUN=false

# 日志级别：debug / info / warn / error
LOG_LEVEL=info

# Playwright 动态页面兜底：auto / always / never
# Montreal 页面如果静态抓取和 WooCommerce API 都抓不到，会在 auto 模式下自动尝试 Playwright。
PLAYWRIGHT_MODE=auto
PLAYWRIGHT_TIMEOUT_MS=30000

# 监控页面 URL。通常不需要改。
TORONTO_URL=https://www.alliance-francaise.ca/en/exams/tests/informations-about-tcf-canada/tcf-canada
KUPER_URL=https://www.kuperacademy.ca/en/academics/tcf-canada-tcfq-language-proficiency-testing.html
MONTREAL_URL=https://www.afmontreal.ca/tcf/#/
EDMONTON_URL=https://www.afedmonton.com/en/exams/tcf/
MANITOBA_URL=https://www.afmanitoba.ca/en/exams/tcf/

# Toronto Active Network API，可选。默认不需要。
# 如果以后想直接抓 Active Network 接口，再填下面几项；不填就只监控 Toronto 官方说明页。
# TORONTO_ACTIVE_API_URL=
# TORONTO_ACTIVE_API_METHOD=GET
# TORONTO_ACTIVE_API_BODY=
# TORONTO_ACTIVE_API_HEADERS=
